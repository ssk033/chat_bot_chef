# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Secrets & env — never commit (whitelist examples if you add them)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# prisma (generated client stubs in app dir; migrations stay tracked)
/app/generated/prisma

# IDE / editors
.idea/
.vscode/
*.swp
*.swo
*~

# local tooling
.cursor/

# Kaggle / API key files
kaggle.json
**/kaggle.json

# Hugging Face & ML caches (huge downloads; recreated locally)
**/.cache/huggingface/
**/.torch/

# trained / downloaded model weights (large)
/models/
RecipeModel/
ml-models/**/*.pth
ml-models/**/*.h5
ml-models/**/*.keras
ml-models/**/*.onnx
ml-models/**/*.pb
ml-models/**/*.tflite
ml-models/**/tensorflow_saved_model**/
ml-models/weights/.food_classifier_demo
*.safetensors

# Jupyter
.ipynb_checkpoints/
**/__pycache__/
*.py[cod]
*$py.class
*.so

# Python virtual environments (anywhere in repo)
**/.venv/
**/venv/
**/.venv-*/
ENV/
.env.venv/

# Food AI ML venv (Python 3.12 + stacks; keep local only)
/.venv-food-ai/

# large / local datasets (never push)
recipes_data.csv
*.csv.bak
checkpoints/
uploads/
tmp/
temp/

# logs
logs/
*.log
